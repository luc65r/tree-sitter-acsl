{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "acsl",
      "camelcase": "Acsl",
      "title": "ANSI/ISO C Specification Language",
      "scope": "source.acsl",
      "file-types": [
        "i",
        "h",
        "c"
      ],
      "injection-regex": "^acsl$",
      "class-name": "TreeSitterAcsl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "ANSI/ISO C Specification Language grammar for tree-sitter",
    "authors": [
      {
        "name": "Lucas Ransan",
        "email": "lucas@ransan.fr"
      }
    ],
    "links": {
      "repository": "https://github.com/luc65r/tree-sitter-acsl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}